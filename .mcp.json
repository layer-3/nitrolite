{
    "mcpServers": {
        "github": {
            "command": "gh",
            "args": ["copilot", "mcp"]
        },
        "nitrolite-ts": {
            "command": "npm",
            "args": ["--prefix", "sdk/ts-mcp", "exec", "--", "tsx", "sdk/ts-mcp/src/index.ts"]
        },
        "nitrolite-go": {
            "command": "go",
            "args": ["run", "./sdk/mcp-go"]
        }
    }
}
