# Per-Dockerfile ignore (BuildKit). Used in place of the repo-root
# .dockerignore when building this Dockerfile, so `sdk/ts` is included in
# the build context.

.git/
.github/
.gitignore
.gitmodules
LICENSE
*.md

contracts/
docs/
nitronode/
faucet-app/
cerebro/
pkg/
sdk/go/
sdk/mcp/
sdk/ts-compat/
test/
scripts/

**/node_modules/
**/dist/
**/.DS_Store
**/.env
**/.env.local
**/*.log
