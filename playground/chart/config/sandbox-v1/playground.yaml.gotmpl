config:
  # Public WS URL — consumed in the browser, must be externally reachable.
  nitronodeWsUrl: "wss://nitronode-sandbox.yellow.org/v1/ws"

service:
  http:
    enabled: true
    port: 8080
    # No ingress rewrite: the Vite bundle is built with base=/v1/playground/,
    # so browser asset URLs already include the prefix and nginx serves files
    # from the same prefix in-cluster.
    path: /v1/playground

metrics:
  enabled: false

replicaCount: 1
resources:
  requests: { cpu: 50m, memory: 64Mi, ephemeral-storage: 64Mi }
  limits:   { cpu: 100m, memory: 128Mi, ephemeral-storage: 128Mi }

autoscaling:
  enabled: false

networking:
  # Same host as nitronode-sandbox; routed by path. The TLS secret is already
  # provisioned by the nitronode ingress on this host.
  externalHostname: nitronode-sandbox.yellow.org
  tlsClusterIssuer: zerossl-prod
  gateway:
    enabled: false
  ingress:
    enabled: true
    className: nginx
    tls:
      enabled: true
  ingressRootRedirect:
    enabled: true
